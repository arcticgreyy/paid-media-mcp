{
  "name": "paid-media-mcp",
  "version": "2.0.0",
  "description": "MCP server for paid media teams — connects Claude to campaigns, performance data, attribution results, identity signals, and autonomous agent outputs",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/index.js",
    "dev": "tsx src/index.ts",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src api test",
    "test": "vitest run",
    "tools:md": "npm run build && node scripts/generate-tools-md.mjs"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.3.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.0",
    "eslint": "^10.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
